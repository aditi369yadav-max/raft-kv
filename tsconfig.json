{
  "compilerOptions": {
    "target": "ES2020", "module": "commonjs", "lib": ["ES2020"],
    "outDir": "./dist", "rootDir": "./src",
    "strict": false, "esModuleInterop": true, "skipLibCheck": true,
    "resolveJsonModule": true, "sourceMap": true, "types": ["node"]
  },
  "include": ["src/**/*", "bench/**/*"],
  "exclude": ["node_modules", "dist"]
}
